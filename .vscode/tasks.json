{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: install",
      "type": "npm",
      "script": "install",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "npm: dev",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "nuxt",
        "pattern": [
          {
            "regexp": "^.*$",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local:\\s+http"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "npm: build",
      "type": "npm",
      "script": "build",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "group": "build"
    },
    {
      "label": "npm: generate",
      "type": "npm",
      "script": "generate",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "group": "build"
    },
    {
      "label": "npm: preview",
      "type": "npm",
      "script": "preview",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Terminate: npm: dev",
      "command": "echo ${input:terminateDev}",
      "type": "shell",
      "problemMatcher": [],
      "presentation": { "reveal": "never", "panel": "shared" }
    }
  ],
  "inputs": [
    {
      "id": "terminateDev",
      "type": "command",
      "command": "workbench.action.tasks.terminate",
      "args": "npm: dev"
    }
  ]
}
